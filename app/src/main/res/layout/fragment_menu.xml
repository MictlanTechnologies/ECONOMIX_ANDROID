<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp">

            <!-- ==================== HEADER CARD ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/menuHeaderBg"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="28dp"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/btnPerfil"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:contentDescription="Perfil"
                        android:src="@drawable/ic_profile_placeholder"
                        android:scaleType="centerInside"
                        android:background="@drawable/bg_avatar_circle" />

                    <TextView
                        android:id="@+id/txtHolaUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_hola"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== 2x2 GRID ==================== -->
            <LinearLayout
                android:id="@+id/menuGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <!-- Row 1: GASTOS + INGRESOS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- GASTOS - Dark teal -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileGastos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/menuCardDark"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:id="@+id/gastoFr"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:contentDescription="Acceso a gastos"
                                android:scaleType="fitCenter"
                                android:src="@drawable/gastosop2texto2" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="GASTOS"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- INGRESOS - Silver/light -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileIngresos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/menuCardLight"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:id="@+id/ingresoFr"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:contentDescription="Acceso a ingresos"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ingresosconletras" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="INGRESOS"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: AHORRO + GRÁFICOS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- AHORRO - Silver/light -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileAhorro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/menuCardLight"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:id="@+id/ahorroFr"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:contentDescription="Acceso al ahorro"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ahorrotexto2" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="AHORRO"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- GRÁFICOS - Dark teal -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileGraficas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/menuCardDark"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:id="@+id/graficasFr"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:contentDescription="Acceso a las gráficas"
                                android:scaleType="fitCenter"
                                android:src="@drawable/graficastexto2" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="GRÁFICOS"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== RECENT ACTIVITY ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recentActivityCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/recentActivityBg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:minHeight="120dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_recent_activity"
                        android:textColor="@color/recentActivityText"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#C8D6D6" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_trending_up"
                            android:tint="@color/tealAccent"
                            tools:ignore="UseAppTint" />

                        <TextView
                            android:id="@+id/tvRecentActivity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/label_no_recent_activity"
                            android:textColor="@color/recentActivityText"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Hidden help button for accessibility -->
    <ImageButton
        android:id="@+id/btnAyuda"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:contentDescription="Ayuda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
