<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <ImageButton
        android:id="@+id/btnAyuda"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Ayuda"
        android:padding="8dp"
        android:src="@drawable/ayuda"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Perfil"
        android:padding="8dp"
        android:src="@drawable/usuario"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="Plan de Ahorro"
        android:textColor="@color/economix_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAyuda" />

    <TextView
        android:id="@+id/tvAhorroSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Define tu meta, da seguimiento y celebra tus avances"
        android:textColor="@color/economix_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

    <LinearLayout
        android:id="@+id/miniMenuAhorro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginHorizontal="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAhorroSubtitle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMenuAhorro"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/title_ahorro"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/tealAccent"
            app:cornerRadius="16dp"
            app:icon="@drawable/ahorrotexto2"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMenuPresupuestos"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/title_presupuestos"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_dashboard_black_24dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white"
            app:strokeColor="@color/tealLight"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/actionRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/miniMenuAhorro">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ahorroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:cardBackgroundColor="@color/tealSurface"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/tealLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMetaAhorro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxStrokeColor="@color/tealAccent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMetaAhorro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/label_meta_ahorro"
                            android:inputType="text"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPrecioMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxStrokeColor="@color/tealAccent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrecioMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/label_precio_objetivo"
                            android:inputType="numberDecimal"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilIngresoSeleccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxStrokeColor="@color/tealAccent">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etIngresoSeleccion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/label_selecciona_ingreso"
                            android:inputType="none"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvIngresoDisponible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/label_disponible_ingreso"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFechaAhorro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxStrokeColor="@color/tealAccent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFechaAhorro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/label_fecha_ahorro"
                            android:inputType="date"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAporteAhorro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxStrokeColor="@color/tealAccent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAporteAhorro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/label_monto_aporte"
                            android:inputType="numberDecimal"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerAhorros"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/label_ver_registros"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/tealSurface"
                app:cornerRadius="14dp" />

            <TextView
                android:id="@+id/tvHistorialAhorro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="Historial de ahorro"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAhorrosVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Aún no registras ahorros."
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listaAhorros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/actionRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="Guardar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/tealAccent"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="Eliminar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/module_gastos"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Limpiar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/tealLight"
            app:cornerRadius="14dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/tealSurfaceVariant"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/softWhite"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/navMenuMini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGastos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gastos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/gastosop2texto2"
                    tools:ignore="UseAppTint" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navIngresos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ingresos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ingresosconletras"
                    tools:ignore="UseAppTint" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navAhorro"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ahorro"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ahorrotexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGraficas"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gráficas"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/graficastexto2"
                    tools:ignore="UseAppTint" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>



    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/navMenuMini"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Ir al menú"
        app:backgroundTint="@color/tealAccent"
        app:fabCustomSize="36dp"
        app:maxImageSize="18dp"
        app:srcCompat="@drawable/ic_home_filled"
        app:tint="@color/economix_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
