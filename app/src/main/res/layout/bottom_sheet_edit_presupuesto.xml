<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/tealDark"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnCerrarBottom"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bottom_nav_icon_background"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/softWhite" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnGuardarBottom"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bottom_nav_icon_background"
            android:src="@android:drawable/checkbox_on_background"
            android:tint="@color/goldAccent" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvIconoBottom"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="🍔"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvNombreBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:textColor="@color/softWhite"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:text="Cambiar color del presupuesto"
        android:textColor="@color/softWhite"
        android:textSize="22sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvColores"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvAsignadoActual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="@color/softWhite"
        android:textSize="18sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddDinero"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Añadir dinero"
        android:textAllCaps="false"
        app:backgroundTint="@color/tealAccent"
        app:cornerRadius="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEditarColor"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="Editar color"
        android:textAllCaps="false"
        app:backgroundTint="@color/tealSurface"
        app:cornerRadius="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEliminarPresupuesto"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="Eliminar presupuesto"
        android:textAllCaps="false"
        app:backgroundTint="@android:color/holo_red_light"
        app:cornerRadius="16dp" />

</LinearLayout>
