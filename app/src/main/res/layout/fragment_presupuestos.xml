<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <!-- Top bar -->
    <ImageButton
        android:id="@+id/btnAyudaPres"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Ayuda"
        android:padding="8dp"
        android:src="@drawable/ayuda"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnPerfilPres"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Perfil"
        android:padding="8dp"
        android:src="@drawable/usuario"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTituloPres"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/titulo_nuevo_presupuesto"
        android:textColor="@color/economix_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAyudaPres" />

    <TextView
        android:id="@+id/tvPresSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/subtitulo_presupuesto"
        android:textColor="@color/economix_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTituloPres" />

    <!-- Step indicators -->
    <LinearLayout
        android:id="@+id/stepIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPresSubtitle">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/step1Dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1"
                android:textColor="@color/economix_text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/tealLight" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/step2Dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2"
                android:textColor="@color/economix_text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/tealLight" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/step3Dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="3"
                android:textColor="@color/economix_text_primary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main content - scrollable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarPres"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepIndicators">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STEP 1: Category selection -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/tealSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_paso_1"
                        android:textColor="@color/tealLight"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¿En qué categoría quieres presupuestar?"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupCategoriaPres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresAlimentacion"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_alimentacion"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresTransporte"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_transporte"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresEntretenimiento"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_entretenimiento"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresSalud"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_salud"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresEducacion"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_educacion"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresServicios"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_servicios"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresHogar"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_hogar"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPresOtro"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_otro"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/white"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 2: Amount -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/tealSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_paso_2"
                        android:textColor="@color/tealLight"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¿Cuánto quieres gastar como máximo?"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/tealAccent"
                        app:prefixText="$"
                        app:prefixTextColor="@color/fieldIconTint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMontoMaxPres"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_monto_maximo"
                            android:digits="0123456789.,"
                            android:inputType="numberDecimal"
                            android:textColor="@color/economix_background"
                            android:textColorHint="@color/tealDark"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quick amount buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMonto500"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="$500"
                            android:textColor="@color/economix_text_primary"
                            android:textSize="12sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/tealLight"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMonto1000"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginHorizontal="6dp"
                            android:layout_weight="1"
                            android:text="$1,000"
                            android:textColor="@color/economix_text_primary"
                            android:textSize="12sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/tealLight"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMonto2500"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginHorizontal="6dp"
                            android:layout_weight="1"
                            android:text="$2,500"
                            android:textColor="@color/economix_text_primary"
                            android:textSize="12sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/tealLight"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMonto5000"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="$5,000"
                            android:textColor="@color/economix_text_primary"
                            android:textSize="12sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/tealLight"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 3: Month/Year -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/tealSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_paso_3"
                        android:textColor="@color/tealLight"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¿Para qué mes y año?"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- Month dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMesPres"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            app:boxBackgroundColor="@color/softWhite"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/tealAccent"
                            app:endIconMode="dropdown_menu"
                            app:startIconDrawable="@drawable/ic_calendar_24"
                            app:startIconTint="@color/fieldIconTint">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/etMesPres"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_mes"
                                android:inputType="none"
                                android:textColor="@color/economix_background"
                                android:textColorHint="@color/tealDark"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Year dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAnioPres"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            app:boxBackgroundColor="@color/softWhite"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/tealAccent"
                            app:endIconMode="dropdown_menu">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/etAnioPres"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_anio"
                                android:inputType="none"
                                android:textColor="@color/economix_background"
                                android:textColorHint="@color/tealDark"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarPres"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:text="Guardar Presupuesto"
        android:textAllCaps="false"
        android:textColor="@color/economix_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/tealAccent"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_dashboard_black_24dp"
        app:iconGravity="textStart"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/tealSurfaceVariant"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/softWhite"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/navMenuMini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGastos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gastos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/gastosop2texto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navIngresos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ingresos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ingresosconletras"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navAhorro"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ahorro"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ahorrotexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGraficas"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gráficas"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/graficastexto2"
                    tools:ignore="UseAppTint" />
