<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Perfil"
        android:padding="8dp"
        android:src="@drawable/usuario"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloMenuAhorro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Ahorro y Presupuestos"
        android:textColor="@color/economix_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnPerfil" />

    <TextView
        android:id="@+id/tvSubtitleMenuAhorro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Selecciona el módulo que quieres abrir"
        android:textColor="@color/economix_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloMenuAhorro" />

    <LinearLayout
        android:id="@+id/menuButtonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitleMenuAhorro">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrAhorro"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="110dp"
            android:text="@string/title_ahorro"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/tealAccent"
            app:cornerRadius="24dp"
            app:icon="@drawable/ahorrotexto2"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrPresupuestos"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="110dp"
            android:text="@string/title_presupuestos"
            android:textAllCaps="false"
            android:textColor="@color/economix_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_dashboard_black_24dp"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white"
            app:strokeColor="@color/tealLight"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/tealSurfaceVariant"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/softWhite"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/navMenuMini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGastos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gastos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/gastosop2texto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navIngresos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ingresos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ingresosconletras"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navAhorro"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ahorro"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ahorrotexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGraficas"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gráficas"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/graficastexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/navMenuMini"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Ir al menú"
        app:backgroundTint="@color/tealAccent"
        app:fabCustomSize="36dp"
        app:maxImageSize="18dp"
        app:srcCompat="@drawable/ic_home_filled"
        app:tint="@color/economix_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
