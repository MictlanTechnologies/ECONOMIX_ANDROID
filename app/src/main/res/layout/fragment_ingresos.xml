<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <!-- Top bar -->
    <ImageButton
        android:id="@+id/btnAyudaIng"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Ayuda"
        android:padding="8dp"
        android:src="@drawable/ayuda"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Perfil"
        android:padding="8dp"
        android:src="@drawable/usuario"
        android:tint="@color/economix_text_primary"
        tools:ignore="UseAppTint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="Nuevo Ingreso"
        android:textColor="@color/economix_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAyudaIng" />

    <TextView
        android:id="@+id/tvIngresoSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Registra tus ingresos y mantén tu balance"
        android:textColor="@color/economix_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

    <!-- Main content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/actionRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvIngresoSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Form card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/tealSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Artículo field with icon -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/tealAccent"
                        app:startIconDrawable="@drawable/ic_dashboard_black_24dp"
                        app:startIconTint="@color/fieldIconTint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etArticuloIng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_ingreso_articulo"
                            android:inputType="textCapSentences"
                            android:textColor="@color/economix_text_primary"
                            android:textColorHint="@color/economix_text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Monto field with $ prefix -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/tealAccent"
                        app:prefixText="$"
                        app:prefixTextColor="@color/fieldIconTint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescripcionIng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Monto"
                            android:digits="0123456789.,"
                            android:inputType="numberDecimal"
                            android:textColor="@color/economix_text_primary"
                            android:textColorHint="@color/economix_text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Fecha field with calendar icon -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:boxBackgroundColor="@color/softWhite"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/tealAccent"
                        app:startIconDrawable="@drawable/ic_calendar_24"
                        app:startIconTint="@color/fieldIconTint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFechaIng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_fecha_descriptivo"
                            android:inputType="none"
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/economix_text_primary"
                            android:textColorHint="@color/economix_text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Categoría as dropdown -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="8dp"
                        android:text="Categoría"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupCategoriaIng"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSalario"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_salario"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFreelance"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_freelance"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipNegocio"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_negocio"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInversiones"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_inversiones"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVenta"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_venta"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOtroIng"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cat_ing_otro"
                            android:textColor="@color/economix_text_primary"
                            app:chipBackgroundColor="@color/tealSurfaceVariant"
                            app:checkedIconVisible="true"
                            app:checkedIconTint="@color/tealPrimary"
                            app:chipStrokeColor="@color/tealLight"
                            app:chipStrokeWidth="1dp" />

                    </com.google.android.material.chip.ChipGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:boxBackgroundColor="@color/softWhite"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="@color/tealAccent">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNuevaCategoriaIng"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_nueva_categoria"
                                android:inputType="textCapWords"
                                android:textColor="@color/economix_text_primary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAgregarCategoriaIng"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_agregar_categoria"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:backgroundTint="@color/tealAccent"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/label_etiquetas"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:boxBackgroundColor="@color/softWhite"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="@color/tealAccent">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNuevaEtiquetaIng"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_nueva_etiqueta"
                                android:inputType="textNoSuggestions"
                                android:textColor="@color/economix_text_primary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAgregarEtiquetaIng"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_agregar_etiqueta"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:backgroundTint="@color/tealPrimary"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupEtiquetasIng"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEtiquetasIng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Hidden field to store the category value for compatibility -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPeriodoIng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Recurrente toggle as switch -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/rbRecurrenteIng"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Ingreso recurrente"
                        android:textColor="@color/economix_text_primary"
                        android:textSize="14sp"
                        app:thumbTint="@color/goldAccent"
                        app:trackTint="@color/tealSurfaceVariant" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ver registros button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerIng"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/label_ver_registros"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/tealPrimary"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_search_24"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/actionRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarIng"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="Guardar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/tealAccent"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarIng"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="Eliminar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/module_gastos"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiarIng"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="Limpiar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/tealPrimary"
            app:cornerRadius="14dp" />
    </LinearLayout>

    <!-- Bottom nav bar -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/tealSurfaceVariant"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/softWhite"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/navMenuMini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGastos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gastos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/gastosop2texto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navIngresos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ingresos"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ingresosconletras"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navAhorro"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Ahorro"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ahorrotexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:alpha="0.3"
                android:background="@color/softWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/navGraficas"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bottom_nav_icon_background"
                    android:contentDescription="Gráficas"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/graficastexto2"
                    tools:ignore="UseAppTint" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/navMenuMini"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Ir al menú"
        app:backgroundTint="@color/tealAccent"
        app:fabCustomSize="36dp"
        app:maxImageSize="18dp"
        app:srcCompat="@drawable/ic_home_filled"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
